library(tidyverse)
df <- tibble(read.csv("./time.csv"))
df
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m)) + geom_point()
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m)) + geom_point() + geom_line()
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m)) + geom_point() + geom_line() + labs(
title="n*m vs Time", x="n*m", y="Time (ms)"
)
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m", x="Time (ms)"
)
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m/10e-6)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m (in millions)", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m/10e6)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m (in millions)", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m/10e5)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m (in millions)", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m/10e5)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m (10^5)", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m/10e5)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m (in hundreds of thousands)", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
df <- tibble(read.csv("./time.csv"))
ggplot(df, aes(x=time, y=n_m/10e5)) + geom_point() + geom_line() + labs(
title="n*m vs Time", y="n*m (10e5)", x="Time (ms)"
) + theme(plot.title = element_text(hjust = 0.5))
